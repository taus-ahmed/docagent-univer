# ── DocAgent v2 Environment Variables ─────────────────────────────────────────
# Copy this to .env and fill in your values.
# NEVER commit .env to git.

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=change-me-use-openssl-rand-hex-32

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL (production):
DATABASE_URL=postgresql://docagent:docagent@localhost:5432/docagent

# SQLite (quick dev, no Postgres needed):
# DATABASE_URL=sqlite:///./storage/docagent.db

# ── LLM ───────────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_your_groq_key_here
GEMINI_API_KEY=your_gemini_key_here
PRIMARY_LLM=groq

# Model overrides (optional — defaults are fine):
# GROQ_EXTRACTION_MODEL=llama-3.3-70b-versatile
# GROQ_VISION_MODEL=llama-3.2-90b-vision-preview
# GEMINI_MODEL=gemini-2.0-flash

# ── Storage ───────────────────────────────────────────────────────────────────
STORAGE_BACKEND=local
# LOCAL_UPLOAD_DIR=./storage/uploads
# LOCAL_OUTPUT_DIR=./storage/outputs
# LOCAL_SCHEMAS_DIR=./storage/schemas

# S3 / Cloudflare R2 (Phase 3):
# STORAGE_BACKEND=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=auto
# S3_BUCKET=docagent-files
# S3_ENDPOINT_URL=https://<account>.r2.cloudflarestorage.com

# ── Redis / Celery (Phase 4) ───────────────────────────────────────────────────
# REDIS_URL=redis://localhost:6379/0
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── CORS ──────────────────────────────────────────────────────────────────────
# Add your frontend URLs:
# ALLOWED_ORIGINS=["http://localhost:3000","https://docagent.vercel.app"]
